---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { t } from '../../../i18n/translations';
import { newsArticles } from '../../../i18n/content';

const tr = t('en');
const articles = newsArticles.en;
---

<BaseLayout title={tr.news.title} lang="en">

  <section class="bg-gradient-to-r from-secondary to-secondary-dark text-white py-16">
    <div class="max-w-[1200px] mx-auto px-4 sm:px-6 text-center">
      <h1 class="text-4xl md:text-5xl font-bold">{tr.news.title}</h1>
    </div>
  </section>

  <section class="py-16">
    <div class="max-w-[1200px] mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {articles.map(article => (
          <article class="bg-white rounded-xl shadow-sm border border-neutral-200 overflow-hidden hover:shadow-md transition-shadow group">
            <div class="h-48 bg-gradient-to-br from-primary/20 to-secondary/20 flex items-center justify-center">
              <svg class="w-12 h-12 text-primary/40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 12h10" />
              </svg>
            </div>
            <div class="p-6">
              <time class="text-xs font-semibold text-primary uppercase tracking-wider">{article.date}</time>
              <h2 class="text-lg font-bold mt-2 mb-3 group-hover:text-primary transition-colors">{article.title}</h2>
              <p class="text-sm text-neutral-600 leading-relaxed">{article.excerpt}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
