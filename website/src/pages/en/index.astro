---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t } from '../../i18n/translations';
import { events } from '../../i18n/content';

const tr = t('en');
const upcomingEvents = events.en.filter(e => e.upcoming).slice(0, 3);
---

<BaseLayout title="Home" lang="en" description="GreenSport Graubünden – Sustainable Alpine Sports in Graubünden">

  <!-- Hero -->
  <section class="relative bg-gradient-to-br from-primary-dark via-primary to-secondary text-white py-24 md:py-32">
    <div class="absolute inset-0 bg-[url('data:image/svg+xml,%3Csvg%20width%3D%2260%22%20height%3D%2260%22%20viewBox%3D%220%200%2060%2060%22%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%3E%3Cpath%20d%3D%22M30%200L60%2030L30%2060L0%2030Z%22%20fill%3D%22rgba(255%2C255%2C255%2C0.03)%22%2F%3E%3C%2Fsvg%3E')] opacity-50"></div>
    <div class="relative max-w-[1200px] mx-auto px-4 sm:px-6 text-center">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 leading-tight">{tr.home.heroTitle}</h1>
      <p class="text-lg md:text-xl text-white/80 max-w-2xl mx-auto mb-8">{tr.home.heroSubtitle}</p>
      <a href="/en/events/" class="inline-block bg-accent hover:bg-accent-dark text-secondary-dark font-semibold px-8 py-3 rounded-lg transition-colors shadow-lg hover:shadow-xl">
        {tr.home.heroCta}
      </a>
    </div>
  </section>

  <!-- Highlights -->
  <section class="py-16 -mt-12 relative z-10">
    <div class="max-w-[1200px] mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          { value: tr.home.highlightEvents, label: tr.home.highlightEventsLabel, icon: '📊' },
          { value: tr.home.highlightRegions, label: tr.home.highlightRegionsLabel, icon: '🏔️' },
          { value: tr.home.highlightCo2, label: tr.home.highlightCo2Label, icon: '🌱' },
        ].map(stat => (
          <div class="bg-white rounded-xl shadow-md p-8 text-center hover:shadow-lg transition-shadow border border-neutral-100">
            <div class="text-3xl mb-3">{stat.icon}</div>
            <div class="text-4xl font-bold text-primary mb-2">{stat.value}</div>
            <div class="text-sm text-neutral-600 font-medium">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Events Teaser -->
  <section class="py-16 bg-white">
    <div class="max-w-[1200px] mx-auto px-4 sm:px-6">
      <h2 class="text-3xl font-bold text-center mb-10">{tr.home.eventsTitle}</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {upcomingEvents.map(event => (
          <div class="rounded-xl border border-neutral-200 p-6 hover:shadow-md transition-shadow bg-neutral-50">
            <div class="flex items-center justify-between mb-3">
              <span class="text-xs font-semibold uppercase tracking-wider text-primary bg-primary/10 px-3 py-1 rounded-full">{event.date}</span>
              <span class="text-xs font-bold text-white bg-primary rounded-full px-2 py-1">GS {event.greenScore}</span>
            </div>
            <h3 class="text-lg font-bold mb-2">{event.name}</h3>
            <p class="text-sm text-neutral-600 mb-2">{event.location}</p>
            <p class="text-sm text-neutral-500">{event.description}</p>
          </div>
        ))}
      </div>
      <div class="text-center mt-8">
        <a href="/en/events/" class="text-primary font-semibold hover:text-primary-dark transition-colors">View all events &rarr;</a>
      </div>
    </div>
  </section>

  <!-- Green Score Preview -->
  <section class="py-16">
    <div class="max-w-[1200px] mx-auto px-4 sm:px-6">
      <div class="bg-gradient-to-r from-primary to-secondary rounded-2xl p-8 md:p-12 text-white flex flex-col md:flex-row items-center gap-8">
        <div class="flex-1">
          <h2 class="text-3xl font-bold mb-4">{tr.home.greenScoreTitle}</h2>
          <p class="text-white/80 leading-relaxed mb-6">{tr.home.greenScoreText}</p>
          <a href="#" class="inline-block bg-accent hover:bg-accent-dark text-secondary-dark font-semibold px-6 py-2.5 rounded-lg transition-colors">
            {tr.home.greenScoreCta}
          </a>
        </div>
        <div class="flex-shrink-0">
          <div class="w-32 h-32 rounded-full border-4 border-accent flex items-center justify-center">
            <div class="text-center">
              <div class="text-3xl font-bold">82</div>
              <div class="text-xs text-white/70">/ 100</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Mission -->
  <section class="py-16 bg-white">
    <div class="max-w-[800px] mx-auto px-4 sm:px-6 text-center">
      <h2 class="text-3xl font-bold mb-6">{tr.home.missionTitle}</h2>
      <p class="text-lg text-neutral-600 leading-relaxed">{tr.home.missionText}</p>
    </div>
  </section>

</BaseLayout>
