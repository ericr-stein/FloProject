---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t } from '../../i18n/translations';

const tr = t('de');
---

<BaseLayout title={tr.nav.contact} lang="de">

  <section class="bg-gradient-to-r from-secondary to-secondary-dark text-white py-16">
    <div class="max-w-[1200px] mx-auto px-4 sm:px-6 text-center">
      <h1 class="text-4xl md:text-5xl font-bold">{tr.nav.contact}</h1>
      <p class="mt-4 text-lg text-neutral-200">Wir freuen uns auf den Austausch</p>
    </div>
  </section>

  <section class="py-16">
    <div class="max-w-[1200px] mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">

        <!-- Contact Info -->
        <div>
          <h2 class="text-2xl font-bold mb-6 text-primary">Kontaktinformationen</h2>
          <div class="space-y-6">
            <div class="flex gap-4">
              <div class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center text-primary shrink-0">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              </div>
              <div>
                <h3 class="font-bold text-sm">Adresse</h3>
                <p class="text-sm text-neutral-600 leading-relaxed">Fachhochschule Graubünden (FHGR)<br>Pulvermühlestrasse 57<br>7004 Chur, Schweiz</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center text-primary shrink-0">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              </div>
              <div>
                <h3 class="font-bold text-sm">E-Mail</h3>
                <a href="mailto:greensport@fhgr.ch" class="text-sm text-primary hover:underline">greensport@fhgr.ch</a>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center text-primary shrink-0">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>
              </div>
              <div>
                <h3 class="font-bold text-sm">Social Media</h3>
                <div class="flex gap-3 mt-1">
                  <a href="https://github.com" target="_blank" rel="noopener" class="text-neutral-600 hover:text-primary transition-colors" aria-label="GitHub">
                    <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
                  </a>
                  <a href="https://linkedin.com" target="_blank" rel="noopener" class="text-neutral-600 hover:text-primary transition-colors" aria-label="LinkedIn">
                    <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Location -->
        <div>
          <h2 class="text-2xl font-bold mb-6 text-primary">Standort</h2>
          <div class="aspect-[4/3] rounded-xl bg-secondary/10 border border-neutral-200 flex items-center justify-center mb-4">
            <div class="text-center p-6">
              <svg class="w-12 h-12 mx-auto text-primary mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              <p class="font-bold">FHGR Chur</p>
              <p class="text-sm text-neutral-600">Pulvermühlestrasse 57, 7004 Chur</p>
            </div>
          </div>
          <p class="text-sm text-neutral-600 leading-relaxed">Die Fachhochschule Graubünden befindet sich im Herzen von Chur, der ältesten Stadt der Schweiz und Tor zu den Bündner Alpen.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Get Involved -->
  <section class="py-16 bg-primary text-white">
    <div class="max-w-[800px] mx-auto px-4 sm:px-6 text-center">
      <h2 class="text-3xl font-bold mb-4">Mitmachen</h2>
      <p class="text-lg text-white/80 mb-8 leading-relaxed">Du bist Veranstalter, Gemeindevertreter oder einfach sportbegeistert und umweltbewusst? Werde Teil von GreenSport Graubünden und gestalte die Zukunft des nachhaltigen Alpensports mit.</p>
      <a href="mailto:greensport@fhgr.ch" class="inline-block bg-white text-primary font-bold px-8 py-3 rounded-lg hover:bg-accent hover:text-dark-text transition-colors">Kontakt aufnehmen</a>
    </div>
  </section>

</BaseLayout>
