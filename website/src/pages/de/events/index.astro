---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { t } from '../../../i18n/translations';
import { events } from '../../../i18n/content';

const tr = t('de');
const upcoming = events.de.filter(e => e.upcoming);
const past = events.de.filter(e => !e.upcoming);
---

<BaseLayout title={tr.events.title} lang="de">

  <section class="bg-gradient-to-r from-secondary to-secondary-dark text-white py-16">
    <div class="max-w-[1200px] mx-auto px-4 sm:px-6 text-center">
      <h1 class="text-4xl md:text-5xl font-bold">{tr.events.title}</h1>
    </div>
  </section>

  <!-- Upcoming -->
  <section class="py-16">
    <div class="max-w-[1200px] mx-auto px-4 sm:px-6">
      <h2 class="text-2xl font-bold mb-8 flex items-center gap-3">
        <span class="w-3 h-3 bg-success rounded-full animate-pulse"></span>
        {tr.events.upcoming}
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {upcoming.map(event => (
          <div class="bg-white rounded-xl shadow-sm border border-neutral-200 p-6 hover:shadow-md transition-shadow">
            <div class="flex items-center justify-between mb-4">
              <span class="text-xs font-semibold text-white bg-primary rounded-full px-3 py-1">{event.date}</span>
              <div class="flex items-center gap-1.5">
                <span class="text-xs text-neutral-500">{tr.events.greenScore}</span>
                <span class="text-sm font-bold text-primary bg-primary/10 rounded-full px-2.5 py-0.5">{event.greenScore}</span>
              </div>
            </div>
            <h3 class="text-xl font-bold mb-2">{event.name}</h3>
            <p class="text-sm text-primary font-medium mb-2">{event.location}</p>
            <p class="text-sm text-neutral-600">{event.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Past -->
  <section class="py-16 bg-white">
    <div class="max-w-[1200px] mx-auto px-4 sm:px-6">
      <h2 class="text-2xl font-bold mb-8 text-neutral-600">{tr.events.past}</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {past.map(event => (
          <div class="bg-neutral-50 rounded-xl border border-neutral-200 p-6 opacity-80">
            <div class="flex items-center justify-between mb-4">
              <span class="text-xs font-semibold text-neutral-500 bg-neutral-200 rounded-full px-3 py-1">{event.date}</span>
              <div class="flex items-center gap-1.5">
                <span class="text-xs text-neutral-500">{tr.events.greenScore}</span>
                <span class="text-sm font-bold text-neutral-600 bg-neutral-200 rounded-full px-2.5 py-0.5">{event.greenScore}</span>
              </div>
            </div>
            <h3 class="text-lg font-bold mb-2 text-neutral-700">{event.name}</h3>
            <p class="text-sm text-neutral-500 font-medium mb-2">{event.location}</p>
            <p class="text-sm text-neutral-500">{event.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
