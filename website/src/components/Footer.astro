---
import { t, getLocaleFromUrl, getLocalePath } from '../i18n/translations';

const locale = getLocaleFromUrl(Astro.url);
const tr = t(locale);

const navLinks = [
  { label: tr.nav.home, href: getLocalePath(locale, '/') },
  { label: tr.nav.about, href: getLocalePath(locale, locale === 'de' ? '/ueber-uns/' : '/about/') },
  { label: tr.nav.news, href: getLocalePath(locale, '/news/') },
  { label: tr.nav.events, href: getLocalePath(locale, '/events/') },
];
---

<footer class="bg-secondary text-white mt-16">
  <div class="max-w-[1200px] mx-auto px-4 sm:px-6 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Brand -->
      <div>
        <h3 class="text-lg font-bold mb-2">GreenSport Graubünden</h3>
        <p class="text-sm text-neutral-200 leading-relaxed">{tr.footer.tagline}</p>
      </div>

      <!-- Navigation -->
      <div>
        <h4 class="text-sm font-semibold uppercase tracking-wider mb-3 text-accent">Navigation</h4>
        <ul class="space-y-2">
          {navLinks.map(link => (
            <li><a href={link.href} class="text-sm text-neutral-200 hover:text-accent transition-colors">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h4 class="text-sm font-semibold uppercase tracking-wider mb-3 text-accent">Legal</h4>
        <ul class="space-y-2">
          <li><a href="#" class="text-sm text-neutral-200 hover:text-accent transition-colors">{tr.footer.imprint}</a></li>
          <li><a href="#" class="text-sm text-neutral-200 hover:text-accent transition-colors">{tr.footer.privacy}</a></li>
        </ul>
      </div>
    </div>

    <div class="border-t border-white/20 mt-8 pt-6 text-center">
      <p class="text-xs text-neutral-400">{tr.footer.copyright}</p>
    </div>
  </div>
</footer>
