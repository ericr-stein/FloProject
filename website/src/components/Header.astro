---
import LanguageSwitcher from './LanguageSwitcher.astro';
import { t, getLocaleFromUrl, getLocalePath } from '../i18n/translations';

const locale = getLocaleFromUrl(Astro.url);
const tr = t(locale);

const navLinks = [
  { label: tr.nav.home, href: getLocalePath(locale, '/') },
  { label: tr.nav.about, href: getLocalePath(locale, locale === 'de' ? '/ueber-uns/' : '/about/') },
  { label: tr.nav.news, href: getLocalePath(locale, '/news/') },
  { label: tr.nav.events, href: getLocalePath(locale, '/events/') },
  { label: tr.nav.gallery, href: getLocalePath(locale, locale === 'de' ? '/galerie/' : '/gallery/') },
  { label: tr.nav.data, href: getLocalePath(locale, locale === 'de' ? '/daten/' : '/data/') },
  { label: tr.nav.contact, href: getLocalePath(locale, locale === 'de' ? '/kontakt/' : '/contact/') },
];
---

<header class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-neutral-200 shadow-sm">
  <nav class="max-w-[1200px] mx-auto px-4 sm:px-6 flex items-center justify-between h-16">
    <!-- Logo -->
    <a href={getLocalePath(locale, '/')} class="flex items-center gap-2 font-bold text-xl text-primary hover:text-primary-dark transition-colors">
      <svg class="w-8 h-8" viewBox="0 0 32 32" fill="none">
        <circle cx="16" cy="16" r="14" fill="#2D6A4F" />
        <path d="M16 6 L22 18 H10 Z" fill="#E9C46A" />
        <path d="M12 18 L16 12 L20 18" stroke="white" stroke-width="1.5" fill="none" />
        <path d="M10 22 h12" stroke="white" stroke-width="1.5" />
      </svg>
      GreenSport
    </a>

    <!-- Desktop Nav -->
    <ul class="hidden md:flex items-center gap-4 lg:gap-5">
      {navLinks.map(link => (
        <li>
          <a href={link.href} class="text-sm font-medium text-neutral-600 hover:text-primary transition-colors py-2 border-b-2 border-transparent hover:border-primary">
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <div class="hidden md:flex items-center gap-4">
      <LanguageSwitcher />
    </div>

    <!-- Mobile toggle -->
    <button id="mobile-menu-btn" class="md:hidden p-2 text-neutral-600 hover:text-primary" aria-label="Menu">
      <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path id="menu-open-icon" stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        <path id="menu-close-icon" class="hidden" stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </nav>

  <!-- Mobile Nav -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-neutral-200 bg-white">
    <ul class="px-4 py-3 space-y-2">
      {navLinks.map(link => (
        <li>
          <a href={link.href} class="block py-2 text-sm font-medium text-neutral-600 hover:text-primary">
            {link.label}
          </a>
        </li>
      ))}
    </ul>
    <div class="px-4 pb-3">
      <LanguageSwitcher />
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const openIcon = document.getElementById('menu-open-icon');
  const closeIcon = document.getElementById('menu-close-icon');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
    openIcon?.classList.toggle('hidden');
    closeIcon?.classList.toggle('hidden');
  });
</script>
